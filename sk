#!/usr/bin/env bash
set -euo pipefail

# ============================================================================
# sk - Claude Code Skills Manager
# https://github.com/Passion4ever/cc-skills
# ============================================================================

SK_VERSION="1.0.0"
GITHUB_USER="Passion4ever"
GITHUB_REPO="cc-skills"
GITHUB_BRANCH="main"
SKILLS_DIR="$HOME/.claude/skills"
RAW_BASE="https://raw.githubusercontent.com/${GITHUB_USER}/${GITHUB_REPO}/${GITHUB_BRANCH}"
API_BASE="https://api.github.com/repos/${GITHUB_USER}/${GITHUB_REPO}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ============================================================================
# Helpers
# ============================================================================

info()  { echo -e "${CYAN}[sk]${NC} $*"; }
ok()    { echo -e "${GREEN}[sk]${NC} $*"; }
warn()  { echo -e "${YELLOW}[sk]${NC} $*"; }
err()   { echo -e "${RED}[sk]${NC} $*" >&2; }

ensure_skills_dir() {
    mkdir -p "$SKILLS_DIR"
}

# Get version from a SKILL.md file
parse_version() {
    local file="$1"
    if [[ -f "$file" ]]; then
        grep -m1 '^version:' "$file" 2>/dev/null | sed 's/^version:[[:space:]]*//' | sed 's/[[:space:]]*$//' || true
    else
        echo ""
    fi
}

# Get version from raw content string
parse_version_from_string() {
    echo "$1" | grep -m1 '^version:' 2>/dev/null | sed 's/^version:[[:space:]]*//' | sed 's/[[:space:]]*$//' || true
}

# Get name from a SKILL.md frontmatter
parse_name() {
    local file="$1"
    if [[ -f "$file" ]]; then
        grep -m1 '^name:' "$file" 2>/dev/null | sed 's/^name:[[:space:]]*//' | sed 's/[[:space:]]*$//' || true
    else
        echo ""
    fi
}

# Fetch list of available skills from GitHub
fetch_available_skills() {
    curl -fsSL "${API_BASE}/contents/skills?ref=${GITHUB_BRANCH}" 2>/dev/null \
        | grep '"name"' \
        | sed 's/.*"name": *"//; s/".*//' \
        | sort
}

# Fetch remote SKILL.md content
fetch_remote_skill_md() {
    local skill_name="$1"
    curl -fsSL "${RAW_BASE}/skills/${skill_name}/SKILL.md" 2>/dev/null
}

# List all files in a remote skill directory
fetch_remote_skill_files() {
    local skill_name="$1"
    curl -fsSL "${API_BASE}/contents/skills/${skill_name}?ref=${GITHUB_BRANCH}" 2>/dev/null \
        | grep '"path"' \
        | sed 's/.*"path": *"//; s/".*//'
}

# Download a single file from the repo
download_file() {
    local remote_path="$1"
    local local_path="$2"
    mkdir -p "$(dirname "$local_path")"
    curl -fsSL "${RAW_BASE}/${remote_path}" -o "$local_path" 2>/dev/null
}

# Recursively download a directory from GitHub
download_skill_dir() {
    local skill_name="$1"
    local remote_dir="$2"
    local local_base="$3"

    local contents
    contents=$(curl -fsSL "${API_BASE}/contents/${remote_dir}?ref=${GITHUB_BRANCH}" 2>/dev/null) || return 1

    echo "$contents" | python3 -c "
import json, sys
items = json.load(sys.stdin)
if not isinstance(items, list):
    items = [items]
for item in items:
    print(item['type'], item['path'])
" 2>/dev/null | while read -r item_type item_path; do
        if [[ "$item_type" == "file" ]]; then
            local rel_path="${item_path#skills/${skill_name}/}"
            download_file "$item_path" "${local_base}/${rel_path}"
        elif [[ "$item_type" == "dir" ]]; then
            download_skill_dir "$skill_name" "$item_path" "$local_base"
        fi
    done
}

# ============================================================================
# Commands
# ============================================================================

cmd_install() {
    local target="${1:-}"

    if [[ "$target" == "--all" || "$target" == "-a" ]]; then
        info "正在获取所有可用 skills..."
        local skills
        skills=$(fetch_available_skills)
        if [[ -z "$skills" ]]; then
            err "无法获取 skill 列表，请检查网络"
            exit 1
        fi
        local count=0
        while IFS= read -r skill; do
            [[ -z "$skill" ]] && continue
            if [[ -d "${SKILLS_DIR}/${skill}" ]]; then
                echo -e "  ${DIM}${skill} — 已安装，跳过${NC}"
            else
                _install_one "$skill" && count=$((count + 1))
            fi
        done <<< "$skills"
        ok "安装完成，共安装 ${count} 个 skill"
        return
    fi

    if [[ -z "$target" ]]; then
        err "用法: sk install <skill-name> | -a"
        exit 1
    fi

    if [[ -d "${SKILLS_DIR}/${target}" ]]; then
        warn "${target} 已安装，如需更新请用 sk update ${target}"
        return
    fi

    _install_one "$target"
}

_install_one() {
    local skill_name="$1"
    ensure_skills_dir

    info "正在安装 ${BOLD}${skill_name}${NC}..."

    # Download the entire skill directory
    local dest="${SKILLS_DIR}/${skill_name}"
    mkdir -p "$dest"

    if ! download_skill_dir "$skill_name" "skills/${skill_name}" "$dest"; then
        err "安装失败: ${skill_name}（可能不存在）"
        rm -rf "$dest"
        return 1
    fi

    if [[ ! -f "${dest}/SKILL.md" ]]; then
        err "安装失败: ${skill_name}（未找到 SKILL.md）"
        rm -rf "$dest"
        return 1
    fi

    local version
    version=$(parse_version "${dest}/SKILL.md")
    ok "已安装 ${BOLD}${skill_name}${NC} ${version:+v${version}}"
}

cmd_uninstall() {
    local target="${1:-}"

    if [[ "$target" == "--all" || "$target" == "-a" ]]; then
        local count=0
        for dir in "${SKILLS_DIR}"/*/; do
            [[ -d "$dir" ]] || continue
            local name
            name=$(basename "$dir")
            rm -rf "$dir"
            echo -e "  ${RED}✗${NC} ${name}"
            count=$((count + 1))
        done
        if [[ $count -eq 0 ]]; then
            info "没有已安装的 skill"
        else
            ok "已卸载 ${count} 个 skill"
        fi
        return
    fi

    if [[ -z "$target" ]]; then
        err "用法: sk uninstall <skill-name> | -a"
        exit 1
    fi

    if [[ ! -d "${SKILLS_DIR}/${target}" ]]; then
        err "${target} 未安装"
        exit 1
    fi

    rm -rf "${SKILLS_DIR}/${target}"
    ok "已卸载 ${BOLD}${target}${NC}"
}

cmd_update() {
    local target="${1:-}"

    if [[ "$target" == "--all" || "$target" == "-a" ]]; then
        local count=0
        local updated=0
        for dir in "${SKILLS_DIR}"/*/; do
            [[ -d "$dir" ]] || continue
            local name
            name=$(basename "$dir")
            count=$((count + 1))
            _update_one "$name" && updated=$((updated + 1))
        done
        if [[ $count -eq 0 ]]; then
            info "没有已安装的 skill"
        else
            ok "检查了 ${count} 个 skill，更新了 ${updated} 个"
        fi
        return
    fi

    if [[ -z "$target" ]]; then
        err "用法: sk update <skill-name> | -a"
        exit 1
    fi

    if [[ ! -d "${SKILLS_DIR}/${target}" ]]; then
        err "${target} 未安装，请先 sk install ${target}"
        exit 1
    fi

    _update_one "$target"
}

_update_one() {
    local skill_name="$1"
    local local_file="${SKILLS_DIR}/${skill_name}/SKILL.md"
    local local_ver remote_ver

    local_ver=$(parse_version "$local_file")

    local remote_content
    remote_content=$(fetch_remote_skill_md "$skill_name")
    if [[ -z "$remote_content" ]]; then
        warn "${skill_name}: 仓库中未找到，跳过"
        return 1
    fi

    remote_ver=$(parse_version_from_string "$remote_content")

    if [[ "$local_ver" == "$remote_ver" && -n "$local_ver" ]]; then
        echo -e "  ${DIM}${skill_name} v${local_ver} — 已是最新${NC}"
        return 1
    fi

    # Re-download entire skill
    rm -rf "${SKILLS_DIR}/${skill_name}"
    mkdir -p "${SKILLS_DIR}/${skill_name}"
    download_skill_dir "$skill_name" "skills/${skill_name}" "${SKILLS_DIR}/${skill_name}"

    ok "${skill_name}: ${local_ver:-?} → ${remote_ver:-?}"
    return 0
}


cmd_list() {
    info "正在从仓库获取..."
    local skills
    skills=$(fetch_available_skills)

    if [[ -z "$skills" ]]; then
        err "无法获取，请检查网络"
        exit 1
    fi

    echo -e "${BOLD}可用的 skills:${NC}"
    echo ""
    while IFS= read -r skill; do
        [[ -z "$skill" ]] && continue
        if [[ -d "${SKILLS_DIR}/${skill}" ]]; then
            echo -e "  ${GREEN}●${NC} ${skill} ${DIM}(已安装)${NC}"
        else
            echo -e "  ${CYAN}○${NC} ${skill}"
        fi
    done <<< "$skills"
    echo ""
}

cmd_check() {
    info "正在检查版本..."

    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf '$tmpdir'" RETURN

    # Collect local skills
    for dir in "${SKILLS_DIR}"/*/; do
        [[ -d "$dir" ]] || continue
        local name
        name=$(basename "$dir")
        local ver
        ver=$(parse_version "${dir}/SKILL.md" 2>/dev/null || true)
        echo "${ver}" > "${tmpdir}/local_${name}"
    done

    # Collect remote skills
    local remote_list
    remote_list=$(fetch_available_skills)
    while IFS= read -r skill; do
        [[ -z "$skill" ]] && continue
        local content
        content=$(fetch_remote_skill_md "$skill")
        local ver
        ver=$(parse_version_from_string "$content")
        echo "${ver}" > "${tmpdir}/remote_${skill}"
    done <<< "$remote_list"

    # Build sorted unique skill list
    local all_skills
    all_skills=$(
        (ls "${tmpdir}"/local_* "${tmpdir}"/remote_* 2>/dev/null | xargs -I{} basename {} | sed 's/^local_//; s/^remote_//' | sort -u)
    )

    # Print table
    echo ""
    printf "${BOLD}%-24s %-12s %-12s %s${NC}\n" "Skill" "Local" "Remote" "Status"
    printf "%-24s %-12s %-12s %s\n" "────────────────────────" "────────────" "────────────" "──────────"

    while IFS= read -r skill; do
        [[ -z "$skill" ]] && continue
        local lv="" rv=""
        [[ -f "${tmpdir}/local_${skill}" ]] && lv=$(cat "${tmpdir}/local_${skill}")
        [[ -f "${tmpdir}/remote_${skill}" ]] && rv=$(cat "${tmpdir}/remote_${skill}")
        local lv_display="${lv:-—}"
        local rv_display="${rv:-—}"
        local status
        local has_local=false has_remote=false
        [[ -f "${tmpdir}/local_${skill}" ]] && has_local=true
        [[ -f "${tmpdir}/remote_${skill}" ]] && has_remote=true

        if [[ "$has_local" == false && "$has_remote" == true ]]; then
            status="${CYAN}✦ 未安装${NC}"
        elif [[ "$has_local" == true && "$has_remote" == false ]]; then
            status="${RED}✗ 仓库已移除${NC}"
        elif [[ -n "$lv" && -n "$rv" && "$lv" == "$rv" ]]; then
            status="${GREEN}✓ 最新${NC}"
        elif [[ -n "$lv" && -n "$rv" && "$lv" != "$rv" ]]; then
            status="${YELLOW}⬆ 可更新${NC}"
        else
            # No version fields — compare by content hash
            local local_hash="" remote_hash=""
            if [[ "$has_local" == true ]]; then
                if command -v md5sum &>/dev/null; then
                    local_hash=$(md5sum "${SKILLS_DIR}/${skill}/SKILL.md" 2>/dev/null | cut -d' ' -f1 || echo "")
                else
                    local_hash=$(md5 -q "${SKILLS_DIR}/${skill}/SKILL.md" 2>/dev/null || echo "")
                fi
            fi
            if [[ "$has_remote" == true ]]; then
                local remote_content
                remote_content=$(fetch_remote_skill_md "$skill")
                if command -v md5sum &>/dev/null; then
                    remote_hash=$(echo "$remote_content" | md5sum | cut -d' ' -f1)
                else
                    remote_hash=$(echo "$remote_content" | md5 -q)
                fi
            fi
            if [[ "$local_hash" == "$remote_hash" ]]; then
                status="${GREEN}✓ 最新${NC}"
            else
                status="${YELLOW}⬆ 可更新${NC}"
            fi
        fi

        printf "%-24s %-12s %-12s " "$skill" "$lv_display" "$rv_display"
        echo -e "$status"
    done <<< "$all_skills"
    echo ""
}

cmd_self() {
    local action="${1:-}"

    case "$action" in
        update)
            info "正在更新 sk..."
            local sk_path
            sk_path=$(command -v sk 2>/dev/null || echo "")
            if [[ -z "$sk_path" ]]; then
                err "未找到 sk 命令"
                exit 1
            fi
            if curl -fsSL "${RAW_BASE}/sk" -o "$sk_path" 2>/dev/null; then
                chmod +x "$sk_path"
                ok "sk 已更新到最新版本"
            else
                err "更新失败，请检查网络"
                exit 1
            fi
            ;;
        uninstall)
            local sk_path
            sk_path=$(command -v sk 2>/dev/null || echo "")
            if [[ -z "$sk_path" ]]; then
                err "未找到 sk 命令"
                exit 1
            fi
            echo -e "${YELLOW}即将卸载 sk (${sk_path})${NC}"
            echo -e "${DIM}注意: 已安装的 skills 不会被删除${NC}"
            read -rp "确认卸载? [y/N] " confirm
            if [[ "$confirm" =~ ^[Yy]$ ]]; then
                rm -f "$sk_path"
                ok "sk 已卸载"
                echo -e "${DIM}如需同时卸载所有 skills，手动运行: rm -rf ${SKILLS_DIR}${NC}"
            else
                info "取消"
            fi
            ;;
        *)
            err "用法: sk self <update|uninstall>"
            ;;
    esac
}

cmd_help() {
    cat <<HELP
${BOLD}sk${NC} — Claude Code Skills Manager v${SK_VERSION}

${BOLD}用法:${NC}
  sk i <name>             安装单个 skill (install)
  sk i -a                 安装所有 skills
  sk uni <name>           卸载单个 skill (uninstall)
  sk uni -a               卸载所有 skills
  sk update <name>        更新单个 skill
  sk update -a            更新所有已安装的 skills
  sk list                 查看所有可用 skills
  sk check                对比本地与远程版本
  sk self update          更新 sk 本身
  sk self uninstall       卸载 sk 本身
  sk -h                   显示帮助
  sk -v                   显示版本

${BOLD}示例:${NC}
  sk install smart-git    安装 smart-git skill
  sk check                检查所有版本差异
  sk update -a            一键更新所有

HELP
}

cmd_version() {
    echo "sk v${SK_VERSION}"
}

# ============================================================================
# Main
# ============================================================================

main() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        install|i)      cmd_install "$@" ;;
        uninstall|uni)  cmd_uninstall "$@" ;;
        update)         cmd_update "$@" ;;
        list|ls)        cmd_list ;;
        check)          cmd_check ;;
        self)           cmd_self "$@" ;;
        help|--help|-h) cmd_help ;;
        version|--version|-v) cmd_version ;;
        *)
            err "未知命令: ${cmd}"
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
