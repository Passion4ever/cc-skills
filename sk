#!/usr/bin/env bash
set -euo pipefail

# ============================================================================
# sk - Claude Code Skills Manager
# https://github.com/Passion4ever/cc-skills
# ============================================================================

SK_VERSION="1.3.0"
GITHUB_USER="Passion4ever"
GITHUB_REPO="cc-skills"
GITHUB_BRANCH="main"
SKILLS_DIR="$HOME/.claude/skills"
RAW_BASE="https://raw.githubusercontent.com/${GITHUB_USER}/${GITHUB_REPO}/${GITHUB_BRANCH}"
API_BASE="https://api.github.com/repos/${GITHUB_USER}/${GITHUB_REPO}"

# Colors
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
DIM=$'\033[2m'
NC=$'\033[0m'

# ============================================================================
# Helpers
# ============================================================================

out()   { printf '%s\n' "$*"; }
info()  { out "${CYAN}[sk]${NC} $*"; }
ok()    { out "${GREEN}[sk]${NC} $*"; }
warn()  { out "${YELLOW}[sk]${NC} $*"; }
err()   { out "${RED}[sk]${NC} $*" 1>&2; }

# Parse a field from SKILL.md frontmatter (stdin or file)
parse_field() {
    local field="$1"
    shift
    if [[ $# -gt 0 && -f "$1" ]]; then
        grep -m1 "^${field}:" "$1" 2>/dev/null | sed "s/^${field}:[[:space:]]*//" | sed 's/[[:space:]]*$//' || true
    else
        grep -m1 "^${field}:" 2>/dev/null | sed "s/^${field}:[[:space:]]*//" | sed 's/[[:space:]]*$//' || true
    fi
}

# Cross-platform md5 hash of a string
md5_hash() {
    if command -v md5sum &>/dev/null; then
        echo "$1" | md5sum | cut -d' ' -f1
    else
        echo "$1" | md5 -q
    fi
}

# Get the installed path of sk
get_sk_path() {
    local p
    p=$(command -v sk 2>/dev/null || echo "")
    if [[ -z "$p" ]]; then
        err "未找到 sk 命令"
        exit 1
    fi
    echo "$p"
}

# Fetch list of available skills from GitHub
fetch_available_skills() {
    curl -fsSL "${API_BASE}/contents/skills?ref=${GITHUB_BRANCH}" 2>/dev/null \
        | grep '"name"' \
        | sed 's/.*"name": *"//; s/".*//' \
        | sort
}

# Fetch remote SKILL.md content
fetch_remote_skill_md() {
    curl -fsSL "${RAW_BASE}/skills/${1}/SKILL.md" 2>/dev/null
}

# Download a single file from the repo
download_file() {
    local remote_path="$1" local_path="$2"
    mkdir -p "$(dirname "$local_path")"
    curl -fsSL "${RAW_BASE}/${remote_path}" -o "$local_path" 2>/dev/null
}

# Recursively download a skill directory from GitHub
download_skill_dir() {
    local skill_name="$1" remote_dir="$2" local_base="$3"

    local contents
    contents=$(curl -fsSL "${API_BASE}/contents/${remote_dir}?ref=${GITHUB_BRANCH}" 2>/dev/null) || return 1

    echo "$contents" | python3 -c "
import json, sys
items = json.load(sys.stdin)
if not isinstance(items, list):
    items = [items]
for item in items:
    print(item['type'], item['path'])
" 2>/dev/null | while read -r item_type item_path; do
        if [[ "$item_type" == "file" ]]; then
            download_file "$item_path" "${local_base}/${item_path#skills/${skill_name}/}"
        elif [[ "$item_type" == "dir" ]]; then
            download_skill_dir "$skill_name" "$item_path" "$local_base"
        fi
    done
}

# ============================================================================
# Commands
# ============================================================================

cmd_install() {
    local target="${1:-}"

    if [[ "$target" == "--all" || "$target" == "-a" ]]; then
        info "正在获取所有可用 skills..."
        local skills
        skills=$(fetch_available_skills)
        [[ -z "$skills" ]] && { err "无法获取 skill 列表，请检查网络"; exit 1; }
        local count=0
        while IFS= read -r skill; do
            [[ -z "$skill" ]] && continue
            if [[ -d "${SKILLS_DIR}/${skill}" ]]; then
                out "  ${DIM}${skill} — 已安装，跳过${NC}"
            else
                _install_one "$skill" && count=$((count + 1))
            fi
        done <<< "$skills"
        ok "安装完成，共安装 ${count} 个 skill"
        return
    fi

    [[ -z "$target" ]] && { err "用法: sk install <skill-name> | -a"; exit 1; }

    if [[ -d "${SKILLS_DIR}/${target}" ]]; then
        warn "${target} 已安装，如需更新请用 sk update ${target}"
        return
    fi

    _install_one "$target"
}

_install_one() {
    local skill_name="$1"
    local dest="${SKILLS_DIR}/${skill_name}"
    mkdir -p "$SKILLS_DIR" "$dest"

    info "正在安装 ${BOLD}${skill_name}${NC}..."

    if ! download_skill_dir "$skill_name" "skills/${skill_name}" "$dest"; then
        err "安装失败: ${skill_name}（可能不存在）"
        rm -rf "$dest"
        return 1
    fi

    if [[ ! -f "${dest}/SKILL.md" ]]; then
        err "安装失败: ${skill_name}（未找到 SKILL.md）"
        rm -rf "$dest"
        return 1
    fi

    local version
    version=$(parse_field version "${dest}/SKILL.md")
    ok "已安装 ${BOLD}${skill_name}${NC} ${version:+v${version}}"
}

cmd_uninstall() {
    local target="${1:-}"

    if [[ "$target" == "--all" || "$target" == "-a" ]]; then
        local count=0
        for dir in "${SKILLS_DIR}"/*/; do
            [[ -d "$dir" ]] || continue
            local name
            name=$(basename "$dir")
            rm -rf "$dir"
            out "  ${RED}✗${NC} ${name}"
            count=$((count + 1))
        done
        [[ $count -eq 0 ]] && info "没有已安装的 skill" || ok "已卸载 ${count} 个 skill"
        return
    fi

    [[ -z "$target" ]] && { err "用法: sk uninstall <skill-name> | -a"; exit 1; }
    [[ ! -d "${SKILLS_DIR}/${target}" ]] && { err "${target} 未安装"; exit 1; }

    rm -rf "${SKILLS_DIR}/${target}"
    ok "已卸载 ${BOLD}${target}${NC}"
}

cmd_update() {
    local target="${1:-}"

    if [[ "$target" == "--all" || "$target" == "-a" ]]; then
        local count=0 updated=0
        for dir in "${SKILLS_DIR}"/*/; do
            [[ -d "$dir" ]] || continue
            count=$((count + 1))
            _update_one "$(basename "$dir")" && updated=$((updated + 1))
        done
        [[ $count -eq 0 ]] && info "没有已安装的 skill" || ok "检查了 ${count} 个 skill，更新了 ${updated} 个"
        return
    fi

    [[ -z "$target" ]] && { err "用法: sk update <skill-name> | -a"; exit 1; }
    [[ ! -d "${SKILLS_DIR}/${target}" ]] && { err "${target} 未安装，请先 sk install ${target}"; exit 1; }

    _update_one "$target"
}

_update_one() {
    local skill_name="$1"
    local local_ver remote_ver remote_content

    local_ver=$(parse_field version "${SKILLS_DIR}/${skill_name}/SKILL.md")

    remote_content=$(fetch_remote_skill_md "$skill_name")
    [[ -z "$remote_content" ]] && { warn "${skill_name}: 仓库中未找到，跳过"; return 1; }

    remote_ver=$(echo "$remote_content" | parse_field version)

    if [[ -n "$local_ver" && "$local_ver" == "$remote_ver" ]]; then
        out "  ${DIM}${skill_name} v${local_ver} — 已是最新${NC}"
        return 1
    fi

    rm -rf "${SKILLS_DIR}/${skill_name}"
    mkdir -p "${SKILLS_DIR}/${skill_name}"
    download_skill_dir "$skill_name" "skills/${skill_name}" "${SKILLS_DIR}/${skill_name}"

    ok "${skill_name}: ${local_ver:-?} → ${remote_ver:-?}"
}

cmd_list() {
    info "正在从仓库获取..."

    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf '$tmpdir'" RETURN

    # Collect local versions
    for dir in "${SKILLS_DIR}"/*/; do
        [[ -d "$dir" ]] || continue
        local name
        name=$(basename "$dir")
        parse_field version "${dir}/SKILL.md" > "${tmpdir}/local_${name}"
    done

    # Collect remote versions
    local remote_list
    remote_list=$(fetch_available_skills)
    [[ -z "$remote_list" ]] && { err "无法获取，请检查网络"; exit 1; }
    while IFS= read -r skill; do
        [[ -z "$skill" ]] && continue
        (fetch_remote_skill_md "$skill" || true) | parse_field version > "${tmpdir}/remote_${skill}"
    done <<< "$remote_list"

    # Build skill lists: installed first, then uninstalled
    local installed="" uninstalled=""
    local all_names
    all_names=$(ls "${tmpdir}"/local_* "${tmpdir}"/remote_* 2>/dev/null \
        | xargs -I{} basename {} | sed 's/^local_//; s/^remote_//' | sort -u)

    while IFS= read -r skill; do
        [[ -z "$skill" ]] && continue
        if [[ -f "${tmpdir}/local_${skill}" ]]; then
            installed="${installed}${skill}"$'\n'
        else
            uninstalled="${uninstalled}${skill}"$'\n'
        fi
    done <<< "$all_names"

    # Print table using tab-separated columns
    out ""
    local fmt="  %-20s %-10s %-10s %s\n"
    printf "${BOLD}${fmt}${NC}" "Skill" "Local" "Remote" "Status"
    printf "  %-20s %-10s %-10s %s\n" "--------------------" "----------" "----------" "----------"

    local ordered="${installed}${uninstalled}"
    while IFS= read -r skill; do
        [[ -z "$skill" ]] && continue
        local lv="" rv=""
        [[ -f "${tmpdir}/local_${skill}" ]] && lv=$(cat "${tmpdir}/local_${skill}")
        [[ -f "${tmpdir}/remote_${skill}" ]] && rv=$(cat "${tmpdir}/remote_${skill}")
        local has_local=false has_remote=false
        [[ -f "${tmpdir}/local_${skill}" ]] && has_local=true
        [[ -f "${tmpdir}/remote_${skill}" ]] && has_remote=true
        local status

        if [[ "$has_local" == false && "$has_remote" == true ]]; then
            status="${CYAN}not installed${NC}"
        elif [[ "$has_local" == true && "$has_remote" == false ]]; then
            status="${RED}removed${NC}"
        elif [[ -n "$lv" && -n "$rv" && "$lv" == "$rv" ]]; then
            status="${GREEN}up to date${NC}"
        elif [[ -n "$lv" && -n "$rv" ]]; then
            status="${YELLOW}update available${NC}"
        else
            # No version fields — compare by content hash
            local local_hash="" remote_hash=""
            [[ "$has_local" == true ]] && local_hash=$(md5_hash "$(cat "${SKILLS_DIR}/${skill}/SKILL.md" 2>/dev/null)")
            [[ "$has_remote" == true ]] && remote_hash=$(md5_hash "$(fetch_remote_skill_md "$skill")")
            [[ "$local_hash" == "$remote_hash" ]] && status="${GREEN}up to date${NC}" || status="${YELLOW}update available${NC}"
        fi

        printf "  %-20s %-10s %-10s " "$skill" "${lv:--}" "${rv:--}"
        out "$status"
    done <<< "$ordered"
    out ""
}

cmd_self() {
    local action="${1:-}"

    case "$action" in
        update)
            info "正在更新 sk..."
            local sk_path
            sk_path=$(get_sk_path)
            local tmp
            tmp=$(mktemp)
            if curl -fsSL -H "Accept: application/vnd.github.v3.raw" "${API_BASE}/contents/sk?ref=${GITHUB_BRANCH}" -o "$tmp" 2>/dev/null; then
                chmod +x "$tmp"
                mv -f "$tmp" "$sk_path"
                local new_ver
                new_ver=$(grep -m1 '^SK_VERSION=' "$sk_path" | sed 's/SK_VERSION="//' | sed 's/"//')
                ok "sk 已更新到 ${BOLD}v${new_ver:-unknown}${NC}"
                exit 0
            else
                rm -f "$tmp"
                err "更新失败，请检查网络"
                exit 1
            fi
            ;;
        uninstall)
            local sk_path
            sk_path=$(get_sk_path)
            out "${YELLOW}即将卸载 sk (${sk_path})${NC}"
            out "${DIM}注意: 已安装的 skills 不会被删除${NC}"
            read -rp "确认卸载? [y/N] " confirm
            if [[ "$confirm" =~ ^[Yy]$ ]]; then
                rm -f "$sk_path"
                ok "sk 已卸载"
                out "${DIM}如需同时卸载所有 skills，手动运行: rm -rf ${SKILLS_DIR}${NC}"
            else
                info "取消"
            fi
            ;;
        *)
            err "用法: sk self <update|uninstall>"
            ;;
    esac
}

cmd_help() {
    out "${BOLD}sk${NC} — Claude Code Skills Manager v${SK_VERSION}"
    out ""
    out "${BOLD}用法:${NC}"
    out "  sk i <name>             安装单个 skill (install)"
    out "  sk i -a                 安装所有 skills"
    out "  sk uni <name>           卸载单个 skill (uninstall)"
    out "  sk uni -a               卸载所有 skills"
    out "  sk update <name>        更新单个 skill"
    out "  sk update -a            更新所有已安装的 skills"
    out "  sk list                 查看所有 skills 及版本状态"
    out "  sk self update          更新 sk 本身"
    out "  sk self uninstall       卸载 sk 本身"
    out "  sk -h                   显示帮助"
    out "  sk -v                   显示版本"
    out ""
    out "${BOLD}示例:${NC}"
    out "  sk install smart-git    安装 smart-git skill"
    out "  sk list                 查看版本状态"
    out "  sk update -a            一键更新所有"
    out ""
}

cmd_version() {
    echo "sk v${SK_VERSION}"
}

# ============================================================================
# Main
# ============================================================================

main() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        install|i)      cmd_install "$@" ;;
        uninstall|uni)  cmd_uninstall "$@" ;;
        update)         cmd_update "$@" ;;
        list|ls)        cmd_list ;;
        self)           cmd_self "$@" ;;
        help|--help|-h) cmd_help ;;
        version|--version|-v) cmd_version ;;
        *)
            err "未知命令: ${cmd}"
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
